generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            BigInt         @id
  username      String?
  firstName     String?
  lastName      String?
  photoUrl      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  subscriptions Subscription[]

  @@map("users")
}

model Product {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  price       Decimal       @db.Decimal(12, 2) @default(0)
  isFree      Boolean       @default(false)
  currency    String        @default("UAH")
  category    String
  images      String[]
  status      ProductStatus @default(ACTIVE)
  userId      BigInt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([category])
  @@index([status])
  @@map("products")
}

model Subscription {
  id           String           @id @default(cuid())
  userId       BigInt
  type         SubscriptionType
  category     String?
  targetUserId BigInt?
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([targetUserId])
  @@map("subscriptions")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD
  ARCHIVED
}

enum SubscriptionType {
  CATEGORY
  USER
}
