# PostgreSQL — Supabase / Vercel Postgres
DATABASE_URL="postgresql://user:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@db.xxx.supabase.co:5432/postgres"

# Токен бота від @BotFather
TELEGRAM_BOT_TOKEN="1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Публічний URL міні-додатку (для кнопок бота та webhook)
WEBAPP_URL="https://your-app.vercel.app"

# Секрет для webhook (опційно, рекомендовано)
TELEGRAM_WEBHOOK_SECRET="random_secret_string"

# Секрет для одноразового налаштування бота (POST /api/telegram/setup)
TELEGRAM_SETUP_SECRET="another_random_secret"
